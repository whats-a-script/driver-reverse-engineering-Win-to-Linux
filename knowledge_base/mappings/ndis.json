{
  "_description": "Extended NDIS → Linux kernel function mappings. Extends AstraForge built-in table.",
  "_format": "{ \"NdisFunctionName\": \"linux_equivalent_or_note\" }",

  "NdisGetSystemUpTimeEx":              "ktime_get_boottime_ns",
  "NdisMGetBusData":                    "pci_read_config_dword",
  "NdisMSetBusData":                    "pci_write_config_dword",
  "NdisOpenConfigurationEx":            "/* use module_param or device_property_read_*() */",
  "NdisCloseConfiguration":             "/* no equivalent — config closed automatically */",
  "NdisReadConfiguration":              "device_property_read_string / of_property_read_u32",
  "NdisWriteConfiguration":             "/* no direct equivalent — use debugfs or sysfs */",
  "NdisAllocateIoWorkItem":             "alloc_workqueue / INIT_WORK",
  "NdisQueueIoWorkItem":                "queue_work",
  "NdisFreeIoWorkItem":                 "destroy_workqueue",
  "NdisMIndicateStatusEx":              "cfg80211_disconnected / ieee80211_connection_loss",
  "NdisMOidRequestComplete":            "/* handled by cfg80211 OID layer */",
  "NdisInitializeListHead":             "INIT_LIST_HEAD",
  "NdisInterlockedInsertTailList":      "list_add_tail + spin_lock",
  "NdisInterlockedRemoveHeadList":      "list_first_entry + list_del + spin_lock",
  "NdisMRegisterScatterGatherDma":      "dma_map_sg / sg_alloc_table",
  "NdisMDeregisterScatterGatherDma":    "dma_unmap_sg / sg_free_table",
  "NdisCancelSendNetBufferLists":       "ieee80211_wake_queues / dev_kfree_skb_any",
  "NdisMResetComplete":                 "ieee80211_wake_queues",
  "NdisScheduleWorkItem":               "schedule_work",
  "NdisMNetPnPEvent":                   "netif_carrier_on / netif_carrier_off",
  "NdisSystemProcessorCount":           "num_online_cpus",
  "NdisGetCurrentProcessorNumber":      "smp_processor_id",
  "NdisGetCurrentSystemTime":           "ktime_get_real_ns",
  "NdisMSleep":                         "usleep_range / msleep",
  "NdisStallExecution":                 "udelay / ndelay",
  "NdisAllocateRWLock":                 "rwlock_t + rwlock_init",
  "NdisAcquireRWLockRead":              "read_lock_irqsave",
  "NdisAcquireRWLockWrite":             "write_lock_irqsave",
  "NdisReleaseRWLock":                  "read_unlock_irqrestore / write_unlock_irqrestore",
  "NdisGetVersion":                     "/* not needed — check LINUX_VERSION_CODE */",
  "NdisWdmGetDeviceObject":             "/* use &pdev->dev directly */",
  "NdisOpenAdapterEx":                  "/* not needed for native driver */",
  "NdisCloseAdapterEx":                 "/* not needed for native driver */",
  "NdisCopyFromNetBufferToNetBuffer":   "skb_copy_bits",
  "NdisCopyFromNetBufferToMemory":      "skb_copy_bits",
  "NdisCopyFromMemoryToNetBuffer":      "skb_store_bits"
}
